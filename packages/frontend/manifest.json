{
  "manifest": {
    "manifestVersion": "1.0.0",
    "version": "1.0.0",
    "technicalName": "MukitApp",
    "requirements": {
      "minCloudApiVersion": "1.0.0"
    },
    "lifecycle": {
      "configurationUrl": "http://localhost:5004/configure",
      "connectUrl": "http://localhost:5004/connect",
      "disconnectUrl": "http://localhost:5004/disconnect"
    },
    "capabilities": {
      "hub": {
        "appLauncher": {
          "redirectUrl": "http://localhost:5004/hub/launch",
          "closedPreviewUrl": "http://localhost:5004/hub/preview"
        }
      },
      "erp": {
        "menuItems": [
          {
            "id": "menu-item-1",
            "name": "Mein Menüpunkt",
            "url": "http://localhost:5004/erp/menu"
          }
        ],
        "api": {
          "scopes": [
            "orders.read",
            "orders.write",
            "items.read"
          ]
        },
        "pane": [
          {
            "id": "pane-1",
            "context": "orders",
            "url": "http://localhost:5004/erp/pane/orders",
            "requiredScopes": [
              "orders.read"
            ]
          }
        ]
      }
    }
  },
  "listing": {
    "version": "1.0.0",
    "listingVersion": "1.0.0",
    "defaultLocale": "de-DE",
    "name": {
      "de-DE": {
        "short": "Meine App",
        "full": "Meine App"
      }
    },
    "description": {
      "de-DE": {
        "short": "Meine App",
        "full": "Meine App"
      }
    },
    "benefits": {
      "de-DE": [
        "benefits"
      ]
    },
    "category": {
      "main": "mainCate",
      "sub": [
        "subCate"
      ]
    },
    "media": {
      "icons": {
        "light": "https://cdn-icons-png.flaticon.com/512/4727/4727424.png",
        "dark": "https://cdn-icons-png.flaticon.com/512/4727/4727424.png"
      },
      "screenshots": [
        "https://picsum.photos/200/200"
      ],
      "video": "https://picsum.photos/200/200"
    },
    "pricing": {
      "freePlan": true
    },
    "support": {
      "url": {
        "de-DE": "https://support.example.com/tickets"
      },
      "documentation": {
        "de-DE": "https://docs.example.com/user-guide"
      }
    },
    "legal": {
      "privacyPolicy": "http://localhost:5004/legal/privacy",
      "termsOfUse": "http://localhost:5004/legal/terms",
      "gdpr": {
        "request": "http://localhost:5004/gdpr/data-request",
        "delete": "http://localhost:5004/gdpr/account-deletion"
      }
    },
    "editorial": {
      "status": true
    },
    "distributionType": "PRIVATE",
    "listingVersionStatus": "DRAFT"
  }
}
