# JTL Analytics MCP Server Configuration

# Azure OpenAI Gateway
OPENAI_API_URL=https://apim-ai-hub-jtlpltf-beta.azure-api.net/openai/v1
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=gpt-4o-mini

# JTL Platform API
JTL_API_URL=https://api.beta.jtl-cloud.com
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
DEMO_TENANT_ID=your-demo-tenant-id

# HTTP Server (for frontend UI)
MCP_HTTP_PORT=3006
